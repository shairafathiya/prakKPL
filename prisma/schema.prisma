datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Note {
  id        String   @id @default(uuid()) // Generates a unique string ID
  title     String
  content   String
  color     String   @default("#FFFFFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}